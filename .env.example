# Environment template for Railway deployment

# Core
NODE_ENV=production
NEXTAUTH_URL=https://<your-app>.railway.app
NEXTAUTH_SECRET=
OPENAI_API_KEY=

# EIA (Brent crude oil history for the Fuel Price chart)
# Optional but recommended. Without it the app uses the shared DEMO_KEY, which is
# rate-limited to ~30 req/hour PER IP and often returns HTTP 429 on Railway
# (shared egress IP). Register a free key (instant) at:
#   https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/db?schema=public

# Optional: Local dev overrides
# For local dev, set NEXTAUTH_URL to http://localhost:3000
# and use your local DB if needed.
# Force rebuild Sun Nov 30 18:31:51 -03 2025
