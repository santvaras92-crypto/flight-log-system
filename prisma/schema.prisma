generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Aircraft {
  matricula        String             @id
  modelo           String?
  hobbs_actual     Decimal            @default(0.0)
  tach_actual      Decimal            @default(0.0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  Component        Component[]
  Flight           Flight[]
  FlightSubmission FlightSubmission[]
  ReplacementPart  ReplacementPart[]
}

model Component {
  id                     Int       @id @default(autoincrement())
  tipo                   String
  horas_acumuladas       Decimal   @default(0.0)
  limite_tbo             Decimal
  aircraftId             String
  last_overhaul_airframe Decimal?
  last_overhaul_date     DateTime?
  overhaul_notes         String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  Aircraft               Aircraft  @relation(fields: [aircraftId], references: [matricula])
}

// ── Plan de Reemplazo (life-limited parts / replacement plan) ──
// Each row of the DGAC "REGISTRO DEL PLAN DE REEMPLAZO" sheets. The remaining
// life is NOT stored here — it is recomputed live against the domain's hour
// meter (AIRFRAME / ENGINE-TSMOH / PROPELLER) and the calendar, so the status
// is always current (the source spreadsheet's "remanente" column is maintained
// inconsistently by hand, which is exactly why we compute it dynamically).
model ReplacementPart {
  id           Int                @id @default(autoincrement())
  aircraftId   String
  dominio      String // "AIRFRAME" | "ENGINE" | "PROPELLER" (which hour meter it tracks)
  descripcion  String // e.g. "Magneto LH", "Carburador", "Filtro aceite motor"
  marca        String?
  partNumber   String?
  serial       String?
  // Limits — either/both may apply (null = N/A). TBO = overhaul interval,
  // Vida Limite = hard life limit. Effective limit = coalesce(vida, tbo).
  tboMeses     Int?
  tboHoras     Decimal?
  vidaMeses    Int?
  vidaHoras    Decimal?
  // Installation reference — the "zero" point for the dynamic countdown.
  installDate  DateTime?
  installHoras Decimal? // domain-hour meter reading at install
  // Sheet's own computed next-due (reference/fallback only).
  proximaFecha DateTime?
  proximaHoras Decimal?
  notas        String?
  orden        Int                @default(0) // preserve source-sheet ordering
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  Aircraft     Aircraft           @relation(fields: [aircraftId], references: [matricula])
  eventos      ReplacementEvent[]

  @@index([aircraftId, dominio])
}

// History of physical component changes/overhauls for a ReplacementPart. Each
// event resets the part's countdown (updates installDate/installHoras/serial).
model ReplacementEvent {
  id          Int             @id @default(autoincrement())
  partId      Int
  fecha       DateTime // date of the change
  horas       Decimal? // domain-hour meter reading at the change
  serialNuevo String? // new serial installed (if it changed)
  notas       String?
  createdAt   DateTime        @default(now())
  Part        ReplacementPart @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
}

model Flight {
  id                   Int                   @id @default(autoincrement())
  submissionId         Int?                  @unique
  fecha                DateTime              @default(now())
  hobbs_inicio         Decimal?
  hobbs_fin            Decimal?
  tach_inicio          Decimal?
  tach_fin             Decimal?
  diff_hobbs           Decimal?
  diff_tach            Decimal?
  costo                Decimal?
  pilotoId             Int?
  aircraftId           String
  copiloto             String?
  cliente              String?
  instructor           String?
  detalle              String?
  createdAt            DateTime              @default(now())
  airframe_hours       Decimal?
  engine_hours         Decimal?
  propeller_hours      Decimal?
  instructor_rate      Decimal?
  piloto_raw           String?
  tarifa               Decimal?
  aerodromoDestino     String?
  aerodromoSalida      String?
  aprobado             Boolean               @default(false)
  Aircraft             Aircraft              @relation(fields: [aircraftId], references: [matricula])
  User                 User?                 @relation(fields: [pilotoId], references: [id])
  FlightSubmission     FlightSubmission?     @relation(fields: [submissionId], references: [id])
  EngineMonitorFlights EngineMonitorFlight[]
  Transaction          Transaction?
}

model FlightSubmission {
  id               Int        @id @default(autoincrement())
  pilotoId         Int
  aircraftId       String
  estado           String     @default("PENDIENTE")
  errorMessage     String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  cliente          String?
  copiloto         String?
  detalle          String?
  fechaVuelo       DateTime?
  hobbsFinal       Decimal?
  instructorRate   Decimal?
  notificado       Boolean    @default(false)
  rate             Decimal?
  tachFinal        Decimal?
  aerodromoDestino String?
  aerodromoSalida  String?
  Flight           Flight?
  Aircraft         Aircraft   @relation(fields: [aircraftId], references: [matricula])
  User             User       @relation(fields: [pilotoId], references: [id])
  ImageLog         ImageLog[]
}

model ImageLog {
  id               Int              @id @default(autoincrement())
  submissionId     Int
  tipo             String
  imageUrl         String
  valorExtraido    Decimal?
  confianza        Decimal?
  validadoManual   Boolean          @default(false)
  createdAt        DateTime         @default(now())
  FlightSubmission FlightSubmission @relation(fields: [submissionId], references: [id])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        Int      @id @default(autoincrement())
  monto     Decimal
  tipo      String
  userId    Int
  flightId  Int?     @unique
  createdAt DateTime @default(now())
  Flight    Flight?  @relation(fields: [flightId], references: [id])
  User      User     @relation(fields: [userId], references: [id])
}

model User {
  id               Int                @id @default(autoincrement())
  nombre           String
  codigo           String?            @unique
  email            String?            @unique
  emailVerified    DateTime?
  rol              String
  saldo_cuenta     Decimal            @default(0.0)
  tarifa_hora      Decimal
  password         String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  fechaNacimiento  DateTime?
  licencia         String?
  telefono         String?
  documento        String?
  tipoDocumento    String?
  resetToken       String?            @unique
  resetTokenExpiry DateTime?
  Account          Account[]
  Deposit          Deposit[]
  DeviceToken      DeviceToken[]
  Flight           Flight[]
  FlightSubmission FlightSubmission[]
  FuelLog          FuelLog[]
  Session          Session[]
  Transaction      Transaction[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Deposit {
  id        Int      @id @default(autoincrement())
  userId    Int
  createdAt DateTime @default(now())
  detalle   String?
  fecha     DateTime @default(now())
  imageUrl  String?
  monto     Decimal
  estado    String   @default("PENDIENTE")
  User      User     @relation(fields: [userId], references: [id])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  fecha     DateTime @default(now())
  litros    Decimal
  monto     Decimal
  imageUrl  String?
  detalle   String?
  createdAt DateTime @default(now())
  estado    String   @default("PENDIENTE")
  User      User     @relation(fields: [userId], references: [id])
}

model DeviceToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  token      String   @unique
  deviceInfo String?
  createdAt  DateTime @default(now())
  lastUsed   DateTime @default(now())
  expiresAt  DateTime
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankMovement {
  id            Int      @id @default(autoincrement())
  correlativo   Int      @unique
  fecha         DateTime
  descripcion   String
  egreso        Decimal?
  ingreso       Decimal?
  saldo         Decimal
  tipo          String   @default("Sin clasificar")
  cliente       String?
  attachmentUrl String?
  uploadBatchId String? // UUID del upload de cartola que creó este movimiento
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([uploadBatchId])
}

model EngineMonitorFlight {
  id             Int                    @id @default(autoincrement())
  flightNumber   Int
  flightDate     DateTime
  aircraftId     String                 @default("CC-AQI")
  engineModel    String                 @default("O-320-D2J")
  engineSerial   String                 @default("RL-7662-39E")
  durationSec    Int                    @default(0)
  maxEGT         Decimal?
  maxCHT         Decimal?
  maxOilTemp     Decimal?
  minOilPress    Decimal?
  avgRPM         Decimal?
  avgFF          Decimal?
  latitude       Decimal?
  longitude      Decimal?
  sourceFile     String?
  isGroundRun    Boolean                @default(false)
  gpsSource      String                 @default("jpi") // "jpi" | "kml" | "none"
  createdAt      DateTime               @default(now())
  linkedFlightId Int?
  readings       EngineMonitorReading[]
  LinkedFlight   Flight?                @relation(fields: [linkedFlightId], references: [id])

  @@unique([flightNumber, flightDate])
  @@index([flightDate])
  @@index([linkedFlightId])
}

// GPS Calibration: learned correction parameters from comparing JPI GPS vs KML GPS
// Updated each time a KML is uploaded, aggregated across all flights
model GpsCalibration {
  id              Int      @id @default(autoincrement())
  aircraftId      String   @default("CC-AQI")
  // Offset corrections (systematic bias in JPI GPS)
  latOffsetDeg    Float    @default(0) // average lat error: JPI - KML
  lonOffsetDeg    Float    @default(0) // average lon error: JPI - KML
  // Smoothing window (optimal moving average window learned from KML comparisons)
  smoothingWindow Int      @default(15) // number of points for moving average
  // Statistics
  sampleCount     Int      @default(0) // number of KML comparisons used
  avgErrorMeters  Float    @default(0) // average position error before correction
  lastUpdated     DateTime @default(now())

  @@unique([aircraftId])
}

model EngineMonitorReading {
  id         Int      @id @default(autoincrement())
  flightId   Int
  elapsedSec Int
  timestamp  DateTime
  egt1       Decimal?
  egt2       Decimal?
  egt3       Decimal?
  egt4       Decimal?
  cht1       Decimal?
  cht2       Decimal?
  cht3       Decimal?
  cht4       Decimal?
  oilTemp    Decimal?
  oilPress   Decimal?
  rpm        Decimal?
  map        Decimal?
  hp         Decimal?
  fuelFlow   Decimal?
  fuelUsed   Decimal?
  fuelRem    Decimal?
  oat        Decimal?
  volts      Decimal?
  carbTemp   Decimal?
  latitude   Decimal?
  longitude  Decimal?
  gpsAlt     Decimal?
  groundSpd  Decimal?

  flight EngineMonitorFlight @relation(fields: [flightId], references: [id], onDelete: Cascade)

  @@index([flightId])
}

// Generic key/value cache that survives redeploys (in-memory cache is wiped on
// every Railway restart). Used e.g. to persist the last-good Brent history
// payload so the chart never goes blank when the upstream EIA API is rate-limited.
model AppCache {
  key       String   @id
  value     String // JSON blob
  updatedAt DateTime @default(now()) @updatedAt
}
