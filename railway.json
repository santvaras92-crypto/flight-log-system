{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "find .next -mindepth 1 -not -path '.next/cache' -not -path '.next/cache/*' -delete 2>/dev/null; rm -rf .next/cache/* 2>/dev/null; npm run build",
    "watchPatterns": ["**/*"]
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 600
  }
}